netButton = () => <ConnectWalletButton\n    limitNetwork={NetworkType.TESTNET}\n    message=\"Augusta Ada King, Countess of Lovelace\"\n    onConnectError={(walletName, error) => {\n      alert(error.message);\n    }} />;"},{"id":"components-connectwalletbutton--balance-button","name":"Balance Button","snippet":"const BalanceButton = () => <ConnectWalletButton\n    showAccountBalance\n    message=\"Augusta Ada King, Countess of Lovelace\"\n    onConnectError={(walletName, error) => {\n      alert(error.message);\n    }} />;"},{"id":"components-connectwalletbutton--p-2-p-button","name":"P 2 P Button","snippet":"const P2PButton = () => <ConnectWalletButton\n    peerConnectEnabled\n    message=\"Augusta Ada King, Countess of Lovelace\"\n    onSignMessage={(signature, key) => {\n      console.log(signature);\n      console.log(key);\n      alert(signature);\n    }}\n    onConnectError={(walletName, error) => {\n      alert(error.message);\n    }} />;"},{"id":"components-connectwalletbutton--cip-95-governance-button","name":"Cip 95 Governance Button","snippet":"const Cip95GovernanceButton = () => <ConnectWalletButton\n    label=\"Connect (CIP-95)\"\n    extensions={[95]}\n    onConnect={(walletName) => {\n      alert(`Connected to ${walletName} with CIP-95 governance extension`);\n    }}\n    onConnectError={(walletName, error) => {\n      alert(error.message);\n    }} />;"},{"id":"components-connectwalletbutton--multiple-extensions-button","name":"Multiple Extensions Button","snippet":"const MultipleExtensionsButton = () => <ConnectWalletButton\n    label=\"Connect (CIP-95 + CIP-103)\"\n    extensions={[95, 103]}\n    onConnect={(walletName) => {\n      alert(`Connected to ${walletName} with CIP-95 and CIP-103 extensions`);\n    }}\n    onConnectError={(walletName, error) => {\n      alert(error.message);\n    }} />;"}],"import":"import { ConnectWalletButton } from \"@cardano-foundation/cardano-connect-with-wallet\";","jsDocTags":{},"reactDocgen":{"description":"","meth